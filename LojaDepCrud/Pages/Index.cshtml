@page
@{
    string loja = "Loja de Vestuário";
}

<p class="text-center bg-success p-3 m-0">Frete Grátis a partir R$150,00 em suas compras </p>

<div id="carouselProdutos" class="carousel slide" data-bs-ride="carousel">
    <!-- Indicadores -->
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#carouselProdutos" data-bs-slide-to="0" class="active"> </button>
        <button type="button" data-bs-target="#carouselProdutos" data-bs-slide-to="1"> </button>
        <button type="button" data-bs-target="#carouselProdutos" data-bs-slide-to="2"> </button>
    </div>
    <!-- Imagens -->
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="https://www.riachuelo.com.br/_next/image?url=https%3A%2F%2Fmidia.fotos-riachuelo.com.br%2Ffotos%2Fmegamenu%2Fhome%2F2026%2Fjunho%2FMEC-2724%2F2%2FHero-MEC-2724-flash-promo-30off1.jpg&w=1920&q=85" class="d-block w-100" alt="Produto 1">
        </div>
        <div class="carousel-item">
            <img src="https://www.riachuelo.com.br/_next/image?url=https%3A%2F%2Fmidia.fotos-riachuelo.com.br%2Ffotos%2Fmegamenu%2Fhome%2F2026%2Fsaldos%2FMEC-2628%2F2%2FHero-MEC-2628-saldos-para-elas.jpg&w=1920&q=85" class="d-block w-100" alt="Produto 2">
        </div>
        <div class="carousel-item">
            <img src="https://www.riachuelo.com.br/_next/image?url=https%3A%2F%2Fmidia.fotos-riachuelo.com.br%2Ffotos%2Fmegamenu%2Fhome%2F2026%2Fjunho%2FMEC-2628%2F1%2FHero-MEC-2628-alto-inverno.jpg&w=1920&q=85" class="d-block w-100" alt="Produto 3">
        </div>
    </div>

    <!-- Botão Anterior -->
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselProdutos" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>

    <!-- Botão Próximo -->
    <button class="carousel-control-next" type="button" data-bs-target="#carouselProdutos" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<div class="bg-verde-escuro text-white p-3">

