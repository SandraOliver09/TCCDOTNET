            </div>

            <!-- Produto 4 -->
            <div class="col-md-3 mb-4">

                <div class="card shadow">

                    <img src="https://static.riachuelo.com.br/RCHLO/16181301001/portrait/1ac585316eb8f88320a6ca5679bfd61f3c58021f.jpg?imwidth=400" class="card-img-top" alt="Mochila">

                    <div class="card-body text-center">

                        <h5 class="card-title">
