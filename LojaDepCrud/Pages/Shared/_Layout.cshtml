<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LojaDepCrud</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LojaDepCrud.styles.css" asp-append-version="true" />
</head>
<body class="">
    <header>
            <nav class= "bg-verde-escuro text-white p-3" > 
                <a href="/" class="text-center titulo"> Susann Moda </a>
                <div class="container mt-4">
                    <div class="row">

                        <div class="col-10">

                            <a href="/outlet" class="btn btn-success">
                                Outlet
                            </a>

                            <a  href="/Feminino" class="btn btn-success">
                                Feminino
                            </a>

                            <a href="Masculino" class="btn btn-success">
                                Masculino
                            </a>

                            <a  href="Infantil" class="btn btn-success">
                                Infantil
                            </a>
                            <a href= "Bolsa" class="btn btn-success">
                                Bolsa
                            </a>

                             <a href="CalcadosCintos" class="btn btn-success">
                                Calçados e Cintos
                            </a>

                            <a href="Novidades" class="btn btn-success">
                                Novidades
                            </a>

                        </div>

                        <div class="col-2">
                            <div class="input-group">
                                <input type="text" class="form-control" placeholder="Pesquisar...">

                                <button class="btn btn-outline-success">
                                    🔍
                                </button>
                            </div>
                        </div>

                    </div>

                </div>
            </nav>
    </header>
    <div>
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-verde-claro text-white">

    <div class="container py-4">

        <div class="row">

            <!-- Empresa -->
            <div class="col-md-4">

                <h4>Susann Moda </h4>

                <p>
                    O melhor mercado online para suas compras.
                </p>

            </div>

            <!-- Links -->
            <div class="col-md-4">

                <h4>Links</h4>

                <ul class="list-unstyled">

                    <li><a href="#" class="text-white text-decoration-none">Início</a></li>

                    <li><a href="#" class="text-white text-decoration-none">Produtos</a></li>

                    <li><a href="#" class="text-white text-decoration-none">Promoções</a></li>

                    <li><a href="#" class="text-white text-decoration-none">Contato</a></li>

                </ul>

            </div>

            <!-- Contato -->
            <div class="col-md-4">

                <h4>Contato</h4>

                <p>📞 (11) 2742-2555</p>

                <p>📧 contato@susannmoda.com</p>

                <p>📍 São Paulo - SP</p>

            </div>

        </div>

    </div>

    <div class="bg-verde-escuro text-center p-3">

        © 2026 Susann Moda - Todos os direitos reservados.

    </div>

</footer>



    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
